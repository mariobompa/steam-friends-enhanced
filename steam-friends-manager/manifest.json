{
  "manifest_version": 3,
  "name": "Steam Friends Manager",
  "version": "1.0.0",
  "description": "Add notes to friends, create custom groups, and organize with drag-and-drop on Steam Community.",
  "permissions": ["storage"],
  "host_permissions": ["https://steamcommunity.com/*"],
  "icons": {
    "16": "images/icon-16.png",
    "128": "images/icon-128.png",
    "512": "images/icon-512.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://steamcommunity.com/*friends*"],
      "js": ["storage.js", "ui/components.js", "content.js"],
      "css": ["ui/styles.css"]
    }
  ]
}
