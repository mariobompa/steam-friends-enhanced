{
  "manifest_version": 3,
  "name": "Steam Friends Manager",
  "version": "0.1",
  "permissions": ["storage"],
  "host_permissions": ["https://steamcommunity.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://steamcommunity.com/*friends*"],
      "js": ["storage.js", "ui/components.js", "content.js"],
      "css": ["ui/styles.css"]
    }
  ]
}
